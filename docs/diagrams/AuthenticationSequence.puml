@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PT
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:Command" as Cmd
participant ":AuthService" as Auth
participant ":Storage" as Storage

User -> PT : run()
activate PT

PT -> Ui : readCommand()
activate Ui
Ui --> PT : fullCommand
deactivate Ui

PT -> Parser : parse(fullCommand)
activate Parser

alt register USERNAME /p PASSWORD
    Parser --> PT : new RegisterCommand(username, password)
else login USERNAME /p PASSWORD
    Parser --> PT : new LoginCommand(username, password)
else logout
    Parser --> PT : new LogoutCommand()
end
deactivate Parser

PT -> Cmd : execute(inventory, ui, customerList)
activate Cmd

alt RegisterCommand
    Cmd -> Auth : register(username, password)
    activate Auth
    Auth --> Cmd : success / validation error
    deactivate Auth
    Cmd -> Ui : printMessage(result)
else LoginCommand
    Cmd -> Auth : login(username, password)
    activate Auth
    Auth --> Cmd : success / validation error
    deactivate Auth
    Cmd -> Ui : printMessage(result)
else LogoutCommand
    Cmd -> Auth : logout()
    activate Auth
    Auth --> Cmd : done
    deactivate Auth
    Cmd -> Ui : printMessage("Logged out successfully")
end

Cmd --> PT
deactivate Cmd

PT -> Storage : saveUsers(authService.getUsersSnapshot())
activate Storage
Storage --> PT
deactivate Storage

PT -> Storage : saveSession(authService.getCurrentUsername())
activate Storage
Storage --> PT
deactivate Storage

deactivate PT
@enduml
