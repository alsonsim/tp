@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PT
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:HelpCommand" as Cmd

User -> PT : "help"
activate PT

PT -> Ui : readCommand()
activate Ui
Ui --> PT : fullCommand
deactivate Ui

PT -> Parser : parse(fullCommand)
activate Parser
Parser --> PT : new HelpCommand()
deactivate Parser

PT -> Cmd : execute(inventory, ui, customerList)
activate Cmd
Cmd -> Ui : printHelpMessage()
activate Ui
Ui --> User : full help menu
Ui --> Cmd
deactivate Ui
Cmd --> PT
deactivate Cmd

deactivate PT
@enduml
