@startuml
skinparam ArrowFontStyle plain
skinparam maxMessageSize 100

actor User
participant ":PharmaTracker" as PharmaTracker
participant "<<class>>\nLoggerSetup" as LoggerSetup
participant ":Ui" as Ui
participant ":Storage" as Storage
participant "inv:Inventory" as Inventory
participant "customerList:CustomerList" as CustomerList
participant ":AuthService" as AuthService
participant ":RestockAlertService" as RestockAlertService
participant "<<class>>\nAppServices" as AppServices
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:Command" as Command

User -> PharmaTracker : launch app (main)
activate PharmaTracker

PharmaTracker -> LoggerSetup : init()
activate LoggerSetup
LoggerSetup --> PharmaTracker
deactivate LoggerSetup

create Ui
PharmaTracker -> Ui : new Ui()
activate Ui
Ui --> PharmaTracker
deactivate Ui

create Storage
PharmaTracker -> Storage : new Storage()
activate Storage
Storage --> PharmaTracker
deactivate Storage

PharmaTracker -> Storage : load()
activate Storage
create Inventory
Storage -> Inventory : new Inventory()
activate Inventory
Inventory --> Storage : inventory
deactivate Inventory
Storage --> PharmaTracker : inventory
deactivate Storage

PharmaTracker -> Storage : loadDispenseLog()
activate Storage
Storage --> PharmaTracker : dispenseLog
deactivate Storage

PharmaTracker -> Inventory : setDispenseLog(dispenseLog)
activate Inventory
Inventory --> PharmaTracker
deactivate Inventory

PharmaTracker -> Storage : loadCustomers()
activate Storage
create CustomerList
Storage -> CustomerList : new CustomerList()
activate CustomerList
CustomerList --> Storage : customerList
deactivate CustomerList
Storage --> PharmaTracker : customerList
deactivate Storage

PharmaTracker -> Storage : loadUsers()
activate Storage
Storage --> PharmaTracker : users
deactivate Storage

PharmaTracker -> Storage : loadSession()
activate Storage
Storage --> PharmaTracker : sessionUsername
deactivate Storage

create AuthService
PharmaTracker -> AuthService : new AuthService(users, sessionUsername)
activate AuthService
AuthService --> PharmaTracker
deactivate AuthService

PharmaTracker -> Storage : loadAlertHistory()
activate Storage
Storage --> PharmaTracker : alertHistory
deactivate Storage

create RestockAlertService
PharmaTracker -> RestockAlertService : new RestockAlertService(alertHistory)
activate RestockAlertService
RestockAlertService --> PharmaTracker
deactivate RestockAlertService

PharmaTracker -> AppServices : initialize(authService, restockAlertService)
activate AppServices
AppServices --> PharmaTracker
deactivate AppServices

PharmaTracker -> RestockAlertService : evaluateInventory(inventory)
activate RestockAlertService
RestockAlertService --> PharmaTracker
deactivate RestockAlertService

PharmaTracker -> Ui : printWelcomeMessage()
activate Ui
Ui --> PharmaTracker
deactivate Ui

loop continuous execution loop

    PharmaTracker -> Ui : readCommand()
    activate Ui
    User --> Ui : input string
    Ui --> PharmaTracker : fullCommand
    deactivate Ui

    alt unauthenticated user issues restricted command
        PharmaTracker -> Ui : printMessage("Authentication required...")
        activate Ui
        Ui --> PharmaTracker
        deactivate Ui
    else command is valid to parse
        PharmaTracker -> Parser : parse(fullCommand)
        activate Parser

        alt invalid command or arguments
            Parser -> Parser : throw PharmaTrackerException
        else valid command
            create Command
            Parser -> Command : instantiate specific command
            activate Command
            Command --> Parser : c
            deactivate Command
        end

        Parser --> PharmaTracker : c
        deactivate Parser

        alt command requires authentication and user not logged in
            PharmaTracker -> Ui : printMessage("Authentication required...")
            activate Ui
            Ui --> PharmaTracker
            deactivate Ui
        else authentication satisfied
            PharmaTracker -> Command : execute(inventory, ui, customerList)
            activate Command

            note right of Command
                Execution details depend
                on the specific command.
            end note

            Command --> PharmaTracker
            deactivate Command

            alt command is not LogoutCommand
                PharmaTracker -> RestockAlertService : evaluateInventory(inventory)
                activate RestockAlertService
                RestockAlertService --> PharmaTracker
                deactivate RestockAlertService
            end

            PharmaTracker -> Storage : save(inventory)
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage

            PharmaTracker -> Storage : saveCustomers(customerList)
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage

            PharmaTracker -> Storage : saveUsers(authService.getUsersSnapshot())
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage

            PharmaTracker -> Storage : saveSession(authService.getCurrentUsername())
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage

            PharmaTracker -> Storage : saveAlertHistory(restockAlertService.getAlertHistory())
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage

            PharmaTracker -> Storage : saveDispenseLog(inventory.getDispenseLog())
            activate Storage
            Storage --> PharmaTracker
            deactivate Storage
        end
    end

end

deactivate PharmaTracker
@enduml
