@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:FindCommand" as FindCommand
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "find paracetamol"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

alt keyword is empty
    Parser -> Parser : throw PharmaTrackerException\n("Please provide a keyword to search for.")
else keyword provided
    create FindCommand
    Parser -> FindCommand : new FindCommand(keyword)
    activate FindCommand
    FindCommand --> Parser : c
    deactivate FindCommand
end

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> FindCommand : execute(inv, ui, customerList)
activate FindCommand

FindCommand -> Inventory : getMedications()
activate Inventory
Inventory --> FindCommand : medicationList
deactivate Inventory

note over FindCommand
  For each medication, getName() is called.
  If the name contains the keyword (case-insensitive),
  the medication is added to matchingMedications.
end note

alt no matching medications found
    FindCommand -> Ui : printMessage("No medications found matching: ...")
    activate Ui
    Ui --> FindCommand
    deactivate Ui
else matches found
    FindCommand -> Ui : printFindResults(matchingMedications)
    activate Ui
    Ui --> FindCommand
    deactivate Ui
end

FindCommand --> PharmaTracker
deactivate FindCommand

deactivate PharmaTracker
@enduml
