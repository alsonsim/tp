@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:SortCommand" as SortCommand
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "sort"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

create SortCommand
Parser -> SortCommand : new SortCommand()
activate SortCommand
SortCommand --> Parser : c
deactivate SortCommand

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> SortCommand : execute(inv, ui, customerList)
activate SortCommand

SortCommand -> Inventory : getMedications()
activate Inventory
Inventory --> SortCommand : medicationList
deactivate Inventory

alt inventory is empty
    SortCommand -> Ui : printMessage("Inventory is empty.")
    activate Ui
    Ui --> SortCommand
    deactivate Ui
else medications present
    note over SortCommand
      medicationList.sort() is called with a Comparator
      that parses each expiry date as yyyy-MM-dd.
      Medications with unparseable dates are placed last
      using LocalDate.MAX as a fallback.
    end note

    SortCommand -> Ui : printMessage(sorted.toString())
    activate Ui
    Ui --> SortCommand
    deactivate Ui
end

SortCommand --> PharmaTracker
deactivate SortCommand

deactivate PharmaTracker
@enduml
