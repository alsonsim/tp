@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:LowStockCommand" as LowStockCommand
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "lowstock /threshold 10"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

alt no arguments provided
    create LowStockCommand
    Parser -> LowStockCommand : new LowStockCommand()
    activate LowStockCommand
    LowStockCommand --> Parser : c
    deactivate LowStockCommand
else /threshold flag provided
    create LowStockCommand
    Parser -> LowStockCommand : new LowStockCommand(threshold)
    activate LowStockCommand
    LowStockCommand --> Parser : c
    deactivate LowStockCommand
end

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> LowStockCommand : execute(inv, ui, customerList)
activate LowStockCommand

LowStockCommand -> Inventory : getMedications()
activate Inventory
Inventory --> LowStockCommand : medicationList
deactivate Inventory

note over LowStockCommand
  For each medication, getQuantity() is called.
  If quantity < threshold, the medication is
  added to lowStockMeds.
end note

LowStockCommand -> Ui : printLowStockList(lowStockMeds, threshold)
activate Ui
Ui --> LowStockCommand
deactivate Ui

LowStockCommand --> PharmaTracker
deactivate LowStockCommand

deactivate PharmaTracker
@enduml
