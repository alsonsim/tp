@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:DispenseSummaryCommand" as DispenseSummaryCommand
participant "inv:Inventory" as Inventory
participant "log:DispenseLog" as DispenseLog
participant ":Storage" as Storage

note over PharmaTracker, Storage
  On startup: Storage.loadDispenseLog() is called
  and the result is installed into Inventory
  via inventory.setDispenseLog(dispenseLog).
end note

User -> PharmaTracker : "dispenselog /date 2026-04-09"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

alt no /date flag provided
    create DispenseSummaryCommand
    Parser -> DispenseSummaryCommand : new DispenseSummaryCommand()
    activate DispenseSummaryCommand
    DispenseSummaryCommand --> Parser : c
    deactivate DispenseSummaryCommand
else valid /date flag provided
    Parser -> Parser : LocalDate.parse(dateStr)
    activate Parser
    Parser --> Parser : date
    deactivate Parser
    create DispenseSummaryCommand
    Parser -> DispenseSummaryCommand : new DispenseSummaryCommand(date)
    activate DispenseSummaryCommand
    DispenseSummaryCommand --> Parser : c
    deactivate DispenseSummaryCommand
else invalid date format
    Parser -> Ui : printMessage("Invalid date format. Use: dispenselog /date YYYY-MM-DD")
    activate Ui
    Ui --> Parser
    deactivate Ui
end

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> DispenseSummaryCommand : execute(inv, ui, customerList)
activate DispenseSummaryCommand

DispenseSummaryCommand -> Inventory : getDispenseLog()
activate Inventory
Inventory --> DispenseSummaryCommand : log
deactivate Inventory

DispenseSummaryCommand -> DispenseLog : getRecordsByDate(date)
activate DispenseLog
DispenseLog --> DispenseSummaryCommand : records
deactivate DispenseLog

DispenseSummaryCommand -> Ui : printDispenseSummary(date, records)
activate Ui
Ui --> DispenseSummaryCommand
deactivate Ui

DispenseSummaryCommand --> PharmaTracker
deactivate DispenseSummaryCommand

PharmaTracker -> Storage : saveDispenseLog(inventory.getDispenseLog())
activate Storage
Storage --> PharmaTracker
deactivate Storage

deactivate PharmaTracker
@enduml
