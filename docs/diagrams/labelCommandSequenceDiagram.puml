@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:LabelCommand" as LabelCommand
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "label 1"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

alt description is empty
    Parser -> Parser : println("Please provide an index for the label.")
else description is not a valid integer
    Parser -> Parser : println("Invalid index. Please enter a valid number.")
else valid index provided
    Parser -> Parser : parseInt(description.trim())
    activate Parser
    Parser --> Parser : index
    deactivate Parser

    create LabelCommand
    Parser -> LabelCommand : new LabelCommand(index)
    activate LabelCommand
    LabelCommand --> Parser : c
    deactivate LabelCommand
end

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> LabelCommand : execute(inv, ui, customerList)
activate LabelCommand

LabelCommand -> Inventory : getMedications()
activate Inventory
Inventory --> LabelCommand : medicationList
deactivate Inventory

alt inventory is empty
    LabelCommand -> Ui : printMessage("Inventory is empty.")
    activate Ui
    Ui --> LabelCommand
    deactivate Ui
else index is out of range
    LabelCommand -> Ui : printMessage("Invalid index...")
    activate Ui
    Ui --> LabelCommand
    deactivate Ui
else valid request
    LabelCommand -> Inventory : getMedication(index - 1)
    activate Inventory
    Inventory --> LabelCommand : med
    deactivate Inventory

    note over LabelCommand
      getName(), getDosage(), getExpiryDate(),
      and getTag() are called on med.
      A formatted label block is printed via Ui.
    end note

    LabelCommand -> Ui : printMessage(label.toString())
    activate Ui
    Ui --> LabelCommand
    deactivate Ui
end

LabelCommand --> PharmaTracker
deactivate LabelCommand

deactivate PharmaTracker
@enduml
