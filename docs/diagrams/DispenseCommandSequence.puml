@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PT
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:DispenseCommand" as Cmd
participant "inv:Inventory" as Inv
participant "log:DispenseLog" as Log
participant "cust:CustomerList" as CustList
participant ":Storage" as Storage

User -> PT : "dispense 1 /q 20 /c 1"
activate PT

PT -> Ui : readCommand()
activate Ui
Ui --> PT : fullCommand
deactivate Ui

PT -> Parser : parse(fullCommand)
activate Parser

alt missing /q or invalid format
    Parser -> Parser : println("Invalid format. Use: dispense INDEX /q QUANTITY [/c CUSTOMER_INDEX]")
    Parser --> PT : null
else valid format
    Parser --> PT : new DispenseCommand(1, 20, 1)
end
deactivate Parser

PT -> Cmd : execute(inventory, ui, customerList)
activate Cmd

alt invalid quantity
    Cmd -> Ui : printMessage("Invalid quantity.")
else empty inventory
    Cmd -> Ui : printMessage("Inventory is empty.")
else invalid medication index
    Cmd -> Ui : printMessage("Invalid index.")
else medication is expired
    Cmd -> Ui : printMessage("Cannot dispense expired medication.")
else quantity exceeds stock
    Cmd -> Ui : printMessage("Insufficient stock.")
else invalid customer index
    Cmd -> Ui : printMessage("Invalid customer index.")
else allergy conflict
    Cmd -> Ui : printAllergyWarning(customerName, allergen)
else all validations pass
    Cmd -> Inv : getMedication(index - 1)
    activate Inv
    Inv --> Cmd : med
    deactivate Inv

    Cmd -> Inv : med.setQuantity(currentQty - quantity)
    Cmd -> Ui : printMessage("Dispensing successfully!")
    Cmd -> Ui : printMessage("Medication: ...")
    Cmd -> Ui : printMessage("Amount: ...")
    Cmd -> Ui : printMessage("Updated Stock: ...")

    Cmd -> Inv : getDispenseLog()
    activate Inv
    Inv --> Cmd : dispenseLog
    deactivate Inv
    Cmd -> Log : addRecord(new DispenseRecord(...))

    alt /c flag provided
        Cmd -> CustList : getCustomer(customerIndex - 1)
        activate CustList
        CustList --> Cmd : customer
        deactivate CustList
        Cmd -> CustList : customer.addDispensingHistory(record)
        Cmd -> Ui : printMessage("Recorded for customer: [C001] ...")
    end

    PT -> Storage : saveDispenseLog(inventory.getDispenseLog())
end

Cmd --> PT
deactivate Cmd
deactivate PT
@enduml
