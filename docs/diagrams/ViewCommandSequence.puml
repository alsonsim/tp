@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:ViewCommand" as ViewCommand
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "view 1"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

alt description is empty
    Parser -> Parser : throw PharmaTrackerException\n("Please provide an index to view.")
else description is not a valid integer
    Parser -> Parser : throw PharmaTrackerException\n("Invalid index. Please enter a valid number.")
else valid index provided
    Parser -> Parser : parseInt(description.trim())
    activate Parser
    Parser --> Parser : index
    deactivate Parser

    create ViewCommand
    Parser -> ViewCommand : new ViewCommand(index)
    activate ViewCommand
    ViewCommand --> Parser : c
    deactivate ViewCommand
end

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> ViewCommand : execute(inv, ui, customerList)
activate ViewCommand

ViewCommand -> Inventory : getMedications()
activate Inventory
Inventory --> ViewCommand : medicationList
deactivate Inventory

alt inventory is empty
    ViewCommand -> Ui : printMessage("Inventory is empty.")
    activate Ui
    Ui --> ViewCommand
    deactivate Ui
else index is out of range
    ViewCommand -> Ui : printMessage("Invalid index...")
    activate Ui
    Ui --> ViewCommand
    deactivate Ui
else valid request
    ViewCommand -> Inventory : getMedication(index - 1)
    activate Inventory
    Inventory --> ViewCommand : med
    deactivate Inventory

    ViewCommand -> Ui : printMedicationDetails(med)
    activate Ui
    Ui --> ViewCommand
    deactivate Ui
end

ViewCommand --> PharmaTracker
deactivate ViewCommand

deactivate PharmaTracker
@enduml
